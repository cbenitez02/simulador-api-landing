---
import Icon from './Icon.astro';
import SectionShell from './ui/SectionShell.astro';
---

<SectionShell id="features">
  <div class="stack-xl">
    <div class="section-heading">
      <h2>Built for Precision</h2>
    </div>

    <div class="feature-grid">
      <article class="feature-card feature-card--wide feature-card--decorated">
        <div class="stack-md feature-card__content">
          <Icon name="neurology" class="feature-card__icon feature-card__icon--secondary" />
          <h3>AI Schema Inference</h3>
          <p>
            Paste a prompt or an example object. Our engine generates a fully typed, dynamic API
            with realistic relations and varied data payloads.
          </p>
        </div>
        <div class="feature-orb feature-orb--secondary" aria-hidden="true"></div>
      </article>

      <article class="feature-card">
        <Icon name="speed" class="feature-card__icon feature-card__icon--primary" />
        <h3>Zero-Latency Edge</h3>
        <p>
          Deployed on global edge nodes. Simulate ideal conditions or inject custom latency to test
          edge cases.
        </p>
      </article>

      <article class="feature-card">
        <Icon name="lock_open" class="feature-card__icon feature-card__icon--warning" />
        <h3>Smart Auth</h3>
        <p>
          Simulate JWT, API Keys, or OAuth flow and verify how your app handles denied states.
        </p>
      </article>

      <article class="feature-card feature-card--wide feature-card--chaos">
        <div class="stack-md feature-card__content">
          <Icon name="warning" class="feature-card__icon feature-card__icon--error" />
          <h3>Chaos Mode</h3>
          <p>
            Inject random failures, 500 errors, and timeouts to ensure your application is resilient
            under pressure.
          </p>
        </div>

        <pre class="error-snippet">{`{ "error": "Internal Server Error", "code": 500, "trace_id": "8x-291-ck9" }`}</pre>
      </article>
    </div>
  </div>
</SectionShell>
