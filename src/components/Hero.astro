---
import MethodChip from './MethodChip.astro';
import { heroActions } from '../content/landing';
---

<section class="hero section" id="top">
  <div class="shell hero__content">
    <span class="eyebrow-pill">Precision Engine v2.4</span>
    <h1>Generate intelligent mock APIs in seconds</h1>
    <p class="hero__lead">
      Stop waiting for the backend. Instantly provision high-performance, AI-driven endpoints
      that mimic production behavior with zero latency.
    </p>

    <div class="hero__actions">
      <a href={heroActions.primary.href} class="button button--primary button--large">
        <span class="material-symbols-outlined" aria-hidden="true">rocket_launch</span>
        {heroActions.primary.label}
      </a>
      <a href={heroActions.secondary.href} class="button button--secondary button--large">
        {heroActions.secondary.label}
      </a>
    </div>

    <div class="dashboard-frame" aria-label="Product preview">
      <div class="dashboard-frame__toolbar">
        <div class="window-dots" aria-hidden="true">
          <span class="window-dot window-dot--error"></span>
          <span class="window-dot window-dot--warning"></span>
          <span class="window-dot window-dot--success"></span>
        </div>
        <span class="dashboard-url">https://api.mock.ai/v1/projects/architect-os</span>
      </div>

      <div class="dashboard-frame__body">
        <aside class="dashboard-sidebar" aria-label="Project navigation">
          <div class="dashboard-sidebar__item dashboard-sidebar__item--active"></div>
          <div class="dashboard-sidebar__item"></div>
          <div class="dashboard-sidebar__item"></div>
          <div class="dashboard-sidebar__item"></div>
        </aside>

        <div class="dashboard-panel glass-panel">
          <div class="dashboard-panel__header">
            <h2>Active Endpoints</h2>
            <span class="status-pill">
              <span class="status-pill__dot"></span>
              3 Endpoints Live
            </span>
          </div>

          <div class="endpoint-list">
            <article class="endpoint-card">
              <div class="endpoint-card__meta">
                <MethodChip method="GET" />
                <span class="endpoint-card__route">/users/profile</span>
              </div>
              <span class="endpoint-card__latency">24ms delay</span>
            </article>

            <article class="endpoint-card">
              <div class="endpoint-card__meta">
                <MethodChip method="POST" />
                <span class="endpoint-card__route">/auth/register</span>
              </div>
              <span class="endpoint-card__latency">420ms delay (Simulated)</span>
            </article>

            <article class="endpoint-card">
              <div class="endpoint-card__meta">
                <MethodChip method="DELETE" />
                <span class="endpoint-card__route">/posts/{'{id}'}</span>
              </div>
              <span class="endpoint-card__latency">Immediate</span>
            </article>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
