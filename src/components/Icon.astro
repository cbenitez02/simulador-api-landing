---
interface Props {
  name: string;
  class?: string;
}

const { name, class: className = '' } = Astro.props;

const icons: Record<string, { viewBox?: string; paths: string[] }> = {
  rocket_launch: {
    paths: [
      'M4.5 19.5 9 15l1.5 1.5 3-3',
      'M14.25 9.75 21 3l-1.5 6.75-3 3',
      'M9 15 6 18l-1.5-1.5 3-3',
      'M15 9 9 15',
      'M12 6.75c2.25-.75 4.5 0 5.25.75s1.5 3  .75 5.25',
    ],
  },
  neurology: {
    paths: [
      'M12 4.5a3 3 0 1 1 0 6 3 3 0 0 1 0-6Z',
      'M8.25 10.5a2.25 2.25 0 1 1 0 4.5 2.25 2.25 0 0 1 0-4.5Z',
      'M15.75 10.5a2.25 2.25 0 1 1 0 4.5 2.25 2.25 0 0 1 0-4.5Z',
      'M12 15.75a2.25 2.25 0 1 1 0 4.5 2.25 2.25 0 0 1 0-4.5Z',
      'M10.5 9.75 9.5 11.25',
      'M13.5 9.75 14.5 11.25',
      'M9.75 14.25 10.75 16.25',
      'M14.25 14.25 13.25 16.25',
    ],
  },
  speed: {
    paths: [
      'M4.5 15.75A8.25 8.25 0 1 1 19.5 21',
      'M12 12 16.5 9.75',
      'M7.5 14.25h1.5',
      'M15 14.25h1.5',
      'M12 7.5V9',
    ],
  },
  lock_open: {
    paths: [
      'M8.25 10.5V8.25a3.75 3.75 0 1 1 7.5 0',
      'M8.25 10.5h7.5a1.5 1.5 0 0 1 1.5 1.5v6A1.5 1.5 0 0 1 15.75 19.5h-7.5A1.5 1.5 0 0 1 6.75 18v-6a1.5 1.5 0 0 1 1.5-1.5Z',
      'M12 13.5v3',
    ],
  },
  warning: {
    paths: [
      'M10.29 4.86 3.72 16.5a1.5 1.5 0 0 0 1.3 2.25h13.96a1.5 1.5 0 0 0 1.3-2.25L13.71 4.86a1.5 1.5 0 0 0-2.62 0Z',
      'M12 9v3.75',
      'M12 15.75h.01',
    ],
  },
  close: {
    paths: [
      'M6.75 6.75 17.25 17.25',
      'M17.25 6.75 6.75 17.25',
    ],
  },
};

const icon = icons[name];

if (!icon) {
  throw new Error(`Unknown icon: ${name}`);
}
---

<svg
  class={`icon ${className}`.trim()}
  viewBox={icon.viewBox ?? '0 0 24 24'}
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  {icon.paths.map((path) => (
    <path d={path}></path>
  ))}
</svg>
