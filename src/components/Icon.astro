---

<svg
  class={`icon ${className}`.trim()}
  viewBox={icon.viewBox ?? '0 0 24 24'}
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  {icon.paths.map((path) => (
    <path d={path}></path>
  ))}
</svg>
