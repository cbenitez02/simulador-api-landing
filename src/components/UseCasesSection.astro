---
import SectionShell from './ui/SectionShell.astro';
import { useCases } from '../content/landing';
---

<SectionShell id="pricing">
  <div class="stack-xl">
    <div class="section-heading section-heading--narrow">
      <h2>Master Your Workflow</h2>
      <p>ArchitectOS adapts to your specific development phase.</p>
    </div>

    <div class="use-cases-grid">
      {useCases.map((item) => (
        <article class={`use-case-card use-case-card--${item.tone}`}>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</SectionShell>
