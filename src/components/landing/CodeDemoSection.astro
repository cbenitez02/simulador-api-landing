---
import { landingContent } from '../../content/landing';

const { requestLabel, requestCode, responseLabel, responseStatus, responseTime, responseCode } = landingContent.demo;
---

<section class="landing-section landing-demo" id="demo">
  <div class="shell landing-demo__grid">
    <article class="landing-demo-panel landing-demo-panel--request">
      <div class="landing-demo-panel__header">
        <span>{requestLabel}</span>
        <div class="landing-demo-panel__dots" aria-hidden="true">
          <span></span><span></span><span></span>
        </div>
      </div>
      <pre>{requestCode.join('\n')}</pre>
      <button type="button" class="landing-demo__copy">↳ COPY CODE</button>
    </article>

    <article class="landing-demo-panel landing-demo-panel--response">
      <div class="landing-demo-panel__header">
        <span>{responseLabel}</span>
        <strong>
          {responseStatus} <span>{responseTime}</span>
        </strong>
      </div>
      <pre>{responseCode.join('\n')}</pre>
    </article>
  </div>
</section>
