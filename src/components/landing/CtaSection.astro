---
import { landingContent, type LandingLink } from '../../content/landing';

const { title, description } = landingContent.cta;
const primaryAction: LandingLink = landingContent.cta.primaryAction;
---

<section class="landing-section landing-cta" id="cta">
  <div class="shell">
    <div class="landing-cta__card">
      <div class="landing-cta__content">
        <h2>{title}</h2>
        <p>{description}</p>
        <a href={primaryAction.href} class="button button--primary button--large">
          {primaryAction.label}
        </a>
      </div>
    </div>
  </div>
</section>
