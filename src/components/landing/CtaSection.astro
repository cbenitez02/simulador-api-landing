---
import SectionShell from '../ui/SectionShell.astro';
import { landingContent } from '../../content/landing';

const { title, description, actions } = landingContent.cta;
---

<!-- v1 has no dedicated login route yet; header login reuses this CTA anchor intentionally. -->
<span id="login" aria-hidden="true"></span>
<SectionShell id="signup" sectionClass="section--cta">
    <div class="cta-card">
      <div class="cta-card__content">
        <h2>
          {title[0]}
          <br />
          <span>{title[1]}</span>
        </h2>
        <p>{description}</p>

        <div class="cta-card__actions">
          <a href={actions.primary.href} class="button button--primary button--large">
            {actions.primary.label}
          </a>
          <a
            href={actions.secondary.href}
            class="button button--secondary button--large"
            title={actions.secondary.placeholderReason}
          >
            {actions.secondary.label}
          </a>
        </div>
      </div>

      <div class="cta-card__glow cta-card__glow--primary" aria-hidden="true"></div>
      <div class="cta-card__glow cta-card__glow--secondary" aria-hidden="true"></div>
    </div>
</SectionShell>
