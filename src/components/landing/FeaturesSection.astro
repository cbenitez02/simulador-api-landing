---
import Icon from '../Icon.astro';
import { landingContent } from '../../content/landing';

const items = [...landingContent.features.items];
---

<section class="landing-section landing-features" id="features">
  <div class="shell landing-features__grid">
    {items.map((item: (typeof items)[number]) => (
      <article class="landing-feature-card">
        <div class={`landing-feature-card__icon landing-tone-panel--${item.tone}`}>
          <Icon name={item.icon} />
        </div>
        <h3>{item.title}</h3>
        <p>{item.description}</p>
      </article>
    ))}
  </div>
</section>
