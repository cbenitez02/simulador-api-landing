---
import { landingContent, type ShellLink } from '../../content/landing';

interface Props {
  pageClass?: 'landing-page' | 'pricing-page';
  brand?: string;
  copyright?: string;
  links?: readonly ShellLink[];
}

const {
  pageClass = 'landing-page',
  brand,
  copyright = landingContent.footer.copyright,
  links: linksOverride,
} = Astro.props;

const resolvedBrand = brand ?? landingContent.footer.brand;
const links = linksOverride ?? landingContent.footer.links;
---

<footer class={`site-footer ${pageClass}__site-footer`.trim()}>
  <div class="shell site-footer__content">
    <div class="site-footer__brand-block">
      <strong>{resolvedBrand}</strong>
      <span>{copyright}</span>
    </div>
    <nav aria-label="Footer">
      {links.map((link) => <a href={link.href}>{link.label}</a>)}
    </nav>
  </div>
</footer>
