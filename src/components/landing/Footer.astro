---
import { landingContent } from '../../content/landing';

const { copyright, links } = landingContent.footer;
---

<footer class="site-footer">
  <div class="shell site-footer__content">
    <span>{copyright}</span>
    <nav aria-label="Footer">
      {links.map((link) => (
        link.href === '#' ? (
          <span class="site-footer__placeholder" title={link.placeholderReason} aria-disabled="true">
            {link.label}
          </span>
        ) : (
          <a href={link.href} title={link.placeholderReason}>{link.label}</a>
        )
      ))}
    </nav>
  </div>
</footer>
