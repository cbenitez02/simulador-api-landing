---
import { landingContent, type LandingLink } from '../../content/landing';

const { brand, copyright } = landingContent.footer;
const links: LandingLink[] = [...landingContent.footer.links];
---

<footer class="site-footer">
  <div class="shell site-footer__content">
    <div class="site-footer__brand-block">
      <strong>{brand}</strong>
      <span>{copyright}</span>
    </div>
    <nav aria-label="Footer">
      {links.map((link) => (
        'href' in link ? (
          <a href={link.href}>{link.label}</a>
        ) : (
          <span class="site-footer__placeholder" title={link.placeholderReason} aria-disabled="true">
            {link.label}
          </span>
        )
      ))}
    </nav>
  </div>
</footer>
