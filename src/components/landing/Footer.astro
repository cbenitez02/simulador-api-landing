---
import { landingContent } from '../../content/landing';

const { copyright, links } = landingContent.footer;
---

<footer class="site-footer">
  <div class="shell site-footer__content">
    <span>{copyright}</span>
    <nav aria-label="Footer">
      {links.map((link) => (
        <a href={link.href} title={link.placeholderReason}>{link.label}</a>
      ))}
    </nav>
  </div>
</footer>
