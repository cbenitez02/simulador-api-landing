---
import { landingContent, type ShellLink } from '../../content/landing';

interface Props {
  activeNavLabel?: string;
  pageClass?: 'landing-page' | 'pricing-page';
  brand?: string;
   primaryAction?: ShellLink;
   navLinks?: readonly ShellLink[];
}

const {
  activeNavLabel,
  pageClass = 'landing-page',
  brand = landingContent.header.brand,
  primaryAction,
  navLinks,
} = Astro.props;

const resolvedNavLinks = navLinks ?? landingContent.header.navLinks;
const resolvedPrimaryAction = primaryAction ?? landingContent.header.primaryAction;
---

<header class={`site-header ${pageClass}__site-header`.trim()}>
  <nav class="shell site-header__shell" aria-label="Primary">
    <div class="site-header__group site-header__group--brand">
      <a href="/" class="site-header__brand">{brand}</a>
      <div class="site-header__nav" aria-label="Sections">
        {resolvedNavLinks.map((link) => (
          <a
            href={link.href}
            class:list={['site-header__link', activeNavLabel === link.label && 'site-header__link--active']}
            aria-current={activeNavLabel === link.label ? 'page' : undefined}
          >
            {link.label}
          </a>
        ))}
      </div>
    </div>

    <div class="site-header__group site-header__group--actions">
      <a href={resolvedPrimaryAction.href} class="button button--primary button--small site-header__action">
        {resolvedPrimaryAction.label}
      </a>
    </div>
  </nav>
</header>
