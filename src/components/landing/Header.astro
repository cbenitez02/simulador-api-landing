---
import { landingContent } from '../../content/landing';

interface Props {
  activeNavLabel?: string;
  pageClass?: 'landing-page' | 'pricing-page';
  brand?: string;
}

const {
  activeNavLabel,
  pageClass = 'landing-page',
  brand = landingContent.header.brand,
} = Astro.props;

type LinkLike = { label: string; href: string } | { label: string; placeholderReason: string };

const headerContent = landingContent.header as {
  brand: string;
  navLinks: readonly LinkLike[];
  primaryAction?: { label: string; href: string };
  actions?: { primary?: { label: string; href: string } };
};

const navLinks = [...headerContent.navLinks] as LinkLike[];
const primaryAction = headerContent.primaryAction ?? headerContent.actions?.primary ?? { label: 'Get Started', href: '#cta' };

function hasHref(link: LinkLike): link is Extract<LinkLike, { href: string }> {
  return 'href' in link;
}
---

<header class={`site-header ${pageClass}__site-header`.trim()}>
  <nav class="shell site-header__shell" aria-label="Primary">
    <div class="site-header__group site-header__group--brand">
      <a href="/" class="site-header__brand">{brand}</a>
      <div class="site-header__nav" aria-label="Sections">
        {navLinks.map((link) => (
          hasHref(link) ? (
            <a
              href={link.href}
              class:list={['site-header__link', activeNavLabel === link.label && 'site-header__link--active']}
              aria-current={activeNavLabel === link.label ? 'page' : undefined}
            >
              {link.label}
            </a>
          ) : (
            <span
              class="site-header__link site-header__link--placeholder"
              title={link.placeholderReason}
              aria-disabled="true"
            >
              {link.label}
            </span>
          )
        ))}
      </div>
    </div>

    <div class="site-header__group site-header__group--actions">
      <a href={primaryAction.href} class="button button--primary button--small site-header__action">
        {primaryAction.label}
      </a>
    </div>
  </nav>
</header>
