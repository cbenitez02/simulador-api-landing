---
import { landingContent } from '../../content/landing';

const { brand, actions } = landingContent.header;
const navLinks = landingContent.header.navLinks as unknown as Array<{
  label: string;
  href: string;
  placeholderReason?: string;
}>;
const navItems = navLinks.map((link) => ({
  ...link,
  isPlaceholder: link.href === '#',
}));
---

<header class="site-header">
  <nav class="shell site-header__shell" aria-label="Primary">
    <div class="site-header__group site-header__group--brand">
      <a href="#top" class="site-header__brand">{brand}</a>
      <div class="site-header__nav" aria-label="Sections">
        {navItems.map((link) => (
          link.isPlaceholder ? (
            <span
              class="site-header__link site-header__link--placeholder"
              title={link.placeholderReason}
              aria-disabled="true"
            >
              {link.label}
            </span>
          ) : (
            <a href={link.href} class="site-header__link">{link.label}</a>
          )
        ))}
      </div>
    </div>

    <div class="site-header__group site-header__group--actions">
      <a href={actions.login.href} class="button button--small site-header__action site-header__action--ghost">
        {actions.login.label}
      </a>
      <a href={actions.signup.href} class="button button--primary button--small site-header__action">
        {actions.signup.label}
      </a>
    </div>
  </nav>
</header>
