---
import Icon from '../Icon.astro';
import MethodChip from '../MethodChip.astro';
import { landingContent } from '../../content/landing';

const { eyebrow, title, lead, actions, preview } = landingContent.hero;
---

<section class="hero section" id="top">
  <div class="shell hero__content">
    <span class="eyebrow-pill">{eyebrow}</span>
    <h1>{title}</h1>
    <p class="hero__lead">{lead}</p>

    <div class="hero__actions">
      <a href={actions.primary.href} class="button button--primary button--large">
        <Icon name={actions.primary.icon} class="hero__action-icon" />
        {actions.primary.label}
      </a>
      <a href={actions.secondary.href} class="button button--secondary button--large">
        {actions.secondary.label}
      </a>
    </div>

    <div class="dashboard-frame" aria-label="Product preview">
      <div class="dashboard-frame__toolbar">
        <div class="window-dots" aria-hidden="true">
          <span class="window-dot window-dot--error"></span>
          <span class="window-dot window-dot--warning"></span>
          <span class="window-dot window-dot--success"></span>
        </div>
        <span class="dashboard-url">{preview.url}</span>
      </div>

      <div class="dashboard-frame__body">
        <aside class="dashboard-sidebar" aria-label="Project navigation">
          <div class="dashboard-sidebar__item dashboard-sidebar__item--active"></div>
          <div class="dashboard-sidebar__item"></div>
          <div class="dashboard-sidebar__item"></div>
          <div class="dashboard-sidebar__item"></div>
        </aside>

        <div class="dashboard-panel glass-panel">
          <div class="dashboard-panel__header">
            <h2>{preview.title}</h2>
            <span class="status-pill">
              <span class="status-pill__dot"></span>
              {preview.status}
            </span>
          </div>

          <div class="endpoint-list">
            {preview.endpoints.map((endpoint) => (
              <article class="endpoint-card">
                <div class="endpoint-card__meta">
                  <MethodChip method={endpoint.method} />
                  <span class="endpoint-card__route">{endpoint.route}</span>
                </div>
                <span class="endpoint-card__latency">{endpoint.latency}</span>
              </article>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
