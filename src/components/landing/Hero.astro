---
import { landingContent, type LandingLink } from '../../content/landing';

const { title, description, actions, visual } = landingContent.hero;
const primaryAction: LandingLink = actions.primary;
const secondaryAction: LandingLink = actions.secondary;
const metrics = [...visual.metrics];
---

<section class="landing-hero landing-section" id="top">
  <div class="shell landing-hero__grid">
    <div class="landing-hero__copy">
      <h1>
        {title.prefix}
        <span>{title.highlight}</span>
        {title.suffix}
      </h1>
      <p>{description}</p>

      <div class="landing-hero__actions">
        {'href' in primaryAction && (
          <a href={primaryAction.href} class="button button--primary button--large">
            {primaryAction.label}
          </a>
        )}
        {'href' in secondaryAction && (
          <a href={secondaryAction.href} class="button button--secondary button--large">
            {secondaryAction.label}
          </a>
        )}
      </div>
    </div>

    <div class="landing-hero__visual" aria-label="Mock Prompt Editor">
      <div class="landing-window-chrome" aria-hidden="true">
        <span class="landing-window-dot landing-window-dot--error"></span>
        <span class="landing-window-dot landing-window-dot--warning"></span>
        <span class="landing-window-dot landing-window-dot--success"></span>
        <span class="landing-hero__visual-label">{visual.label}</span>
      </div>

      <div class="landing-hero__prompt">{visual.prompt}</div>

      <div class="landing-hero__visual-grid">
        <div class="landing-hero__metrics">
          {metrics.map((metric: (typeof metrics)[number]) => (
            <div class="landing-metric-card">
              <div class="landing-metric-card__row">
                <span>{metric.label}</span>
                <strong class={`landing-tone--${metric.tone}`}>{metric.value}</strong>
              </div>
              <div class="landing-progress" aria-hidden="true">
                <span class={`landing-progress__fill landing-progress__fill--${metric.tone}`} style={`width: ${metric.fill};`}></span>
              </div>
            </div>
          ))}
        </div>

        <div class="landing-hero__response">
          <span>{visual.responseTitle}</span>
          <pre>{visual.responseLines.join('\n')}</pre>
        </div>
      </div>
    </div>
  </div>
</section>
