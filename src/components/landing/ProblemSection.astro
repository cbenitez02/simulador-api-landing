---
import Icon from '../Icon.astro';
import SectionShell from '../ui/SectionShell.astro';
import { landingContent } from '../../content/landing';

const { title, description, painPoints, metrics, quote } = landingContent.problem;
---

<SectionShell sectionClass="section--muted" contentClass="shell split-grid split-grid--problem">
    <div class="stack-lg">
      <div class="section-heading section-heading--left">
        <h2>{title}</h2>
        <p>{description}</p>
      </div>

      <ul class="problem-list">
        {painPoints.map((item) => (
          <li>
            <Icon name={item.icon} class="problem-list__icon" />
            <div>
              <strong>{item.title}</strong>
              <p>{item.description}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>

    <div class="stats-grid">
      {metrics.map((item) => (
        <article class:list={['metric-card', item.tone && `metric-card--${item.tone}`]}>
          <strong>{item.value}</strong>
          <span>{item.label}</span>
        </article>
      ))}
      <blockquote class="quote-card">
        <p>{quote.body}</p>
        <footer>{quote.author}</footer>
      </blockquote>
    </div>
</SectionShell>
