---
import Icon from '../Icon.astro';
import { landingContent } from '../../content/landing';

const { title } = landingContent.useCases;
const items = [...landingContent.useCases.items];
---

<section class="landing-section landing-use-cases" id="use-cases">
  <div class="shell">
    <div class="landing-section-heading">
      <h2>{title}</h2>
    </div>

    <div class="landing-use-cases__grid">
      {items.map((item: (typeof items)[number]) => (
        <article class="landing-use-case-card">
          <div class={`landing-use-case-card__icon landing-tone-panel--${item.tone}`}>
            <Icon name={item.icon} />
          </div>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
