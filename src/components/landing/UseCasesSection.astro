---
import SectionShell from '../ui/SectionShell.astro';
import { landingContent } from '../../content/landing';

const { title, description, items } = landingContent.useCases;
---

<SectionShell id="pricing">
  <div class="stack-xl">
    <div class="section-heading section-heading--narrow">
      <h2>{title}</h2>
      <p>{description}</p>
    </div>

    <div class="use-cases-grid">
      {items.map((item) => (
        <article class={`use-case-card use-case-card--${item.tone}`}>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </article>
      ))}
    </div>
  </div>
</SectionShell>
