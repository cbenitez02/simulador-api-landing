---
import '../styles/global.css';
import { landingContent } from '../content/landing';

const canonicalLandingContent = landingContent as {
  seo: { title: string; description: string };
  footer: { brand?: string };
  features: { items: ReadonlyArray<{ title: string }> };
  useCases: { items: ReadonlyArray<{ title: string }> };
};

interface Props {
  title?: string;
  description?: string;
  siteName?: string;
}

const {
  title = canonicalLandingContent.seo.title,
  description = canonicalLandingContent.seo.description,
  siteName = canonicalLandingContent.footer.brand ?? 'Obsidian Architect',
} = Astro.props;
const canonicalUrl = Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : undefined;
const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      name: siteName,
      description,
      inLanguage: 'en',
      ...(canonicalUrl ? { url: canonicalUrl } : {}),
    },
    {
      '@type': 'SoftwareApplication',
      name: siteName,
      applicationCategory: 'DeveloperApplication',
      operatingSystem: 'Web',
      audience: {
        '@type': 'Audience',
        audienceType: 'Frontend teams and developers',
      },
      description,
      featureList: canonicalLandingContent.features.items.map((item) => item.title),
      keywords: canonicalLandingContent.useCases.items.map((item) => item.title).join(', '),
      inLanguage: 'en',
      ...(canonicalUrl ? { url: canonicalUrl } : {}),
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="theme-color" content="#0e0e0e" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <title>{title}</title>
    <link
      rel="preload"
      href="/assets/fonts/inter-latin.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>
    <slot />
  </body>
</html>
