---
import Header from '../components/landing/Header.astro';
import Footer from '../components/landing/Footer.astro';
import PricingComparison from '../components/pricing/PricingComparison.astro';
import PricingFaq from '../components/pricing/PricingFaq.astro';
import PricingHero from '../components/pricing/PricingHero.astro';
import PricingPlans from '../components/pricing/PricingPlans.astro';
import PricingProof from '../components/pricing/PricingProof.astro';
import { pricingContent } from '../content/pricing';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title={pricingContent.seo.title}
  description={pricingContent.seo.description}
  siteName={pricingContent.brand}
>
  <div class="pricing-page">
    <Header
      pageClass="pricing-page"
      activeNavLabel="Pricing"
      brand={pricingContent.header.brand}
    />
    <main id="main-content">
      <PricingHero hero={pricingContent.hero} />
      <PricingPlans plans={pricingContent.plans} />
      <PricingProof cards={pricingContent.proofCards} />
      <PricingComparison comparison={pricingContent.comparison} />
      <PricingFaq items={pricingContent.faq} />
    </main>
    <Footer
      pageClass="pricing-page"
      brand={pricingContent.footer.brand}
      copyright={pricingContent.footer.copyright}
    />
  </div>
</BaseLayout>
